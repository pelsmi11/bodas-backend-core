# Database Configuration
DB_URL=jdbc:postgresql://<db-host>/<db-name>?sslmode=require
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=<aws-profile-name>

# Security - Cognito
COGNITO_ISSUER_URI=https://cognito-idp.us-east-1.amazonaws.com/<user-pool-id>

# App Custom Properties
S3_BUCKET_NAME=<s3-bucket-name>
MODERATION_SECRET_NAME=<secrets-manager-key-name>

# Redis (ElastiCache or local)
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# Set to false for local development when Redis is not reachable
APP_REDIS_LISTENER_ENABLED=true

# Webhook shared secret (must match Lambda header X-Webhook-Secret)
WEBHOOK_SECRET=<change-me>
